# Database
POSTGRES_URL=postgresql://odoo_user:odoo_password@postgres:5432/odoo_saas_db

# Redis & Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# Security (Set strong values in .env!)
SECRET_KEY=generate_a_random_32_char_string
ADMIN_PASSWORD=change_this_immediately
ADMIN_TOKEN=generate_a_random_32_char_string

# CORS — comma-separated list of allowed frontend origins in production
# Leave empty to allow only localhost (dev mode)
ALLOWED_ORIGINS=https://your-app-domain.com

# Set to true only in local development — disables API docs and restricts CORS in production
DEBUG=false

# WhatsApp
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token

# Public base URL of this app (used for Razorpay payment callback URLs)
APP_BASE_URL=https://your-app-domain.com

# Odoo Base URL (Default for first merchant or global)
ODOO_URL=https://your-odoo-instance.com

# Razorpay
RAZORPAY_KEY=rzp_test_your_key
RAZORPAY_SECRET=your_razorpay_secret
